# ============================================
# MODEL 4: AUTOENCODER
# ============================================

import torch
import torch.nn as nn
from torch.utils.data import DataLoader, TensorDataset

# FIX: Train on X_train ONLY (not full dataset) to prevent data leakage
X_train_np = X_train.values.astype(np.float32)
train_dataset = TensorDataset(torch.from_numpy(X_train_np))
train_dataloader = DataLoader(train_dataset, batch_size=32, shuffle=True)

# Define Autoencoder
class Autoencoder(nn.Module):
    def __init__(self, input_dim):
        super(Autoencoder, self).__init__()
        self.encoder = nn.Sequential(
            nn.Linear(input_dim, 16),
            nn.ReLU(),
            nn.Linear(16, 8),
            nn.ReLU(),
            nn.Linear(8, 4)
        )
        self.decoder = nn.Sequential(
            nn.Linear(4, 8),
            nn.ReLU(),
            nn.Linear(8, 16),
            nn.ReLU(),
            nn.Linear(16, input_dim)
        )

    def forward(self, x):
        encoded = self.encoder(x)
        decoded = self.decoder(encoded)
        return decoded

# Train Autoencoder
input_dim = X_train_np.shape[1]
ae_model = Autoencoder(input_dim)  # FIX: renamed from 'model' to 'ae_model' to avoid conflicts
criterion = nn.MSELoss()
optimizer = torch.optim.Adam(ae_model.parameters(), lr=1e-3)

epochs = 50
for epoch in range(epochs):
    epoch_loss = 0
    for batch in train_dataloader:
        data = batch[0]
        optimizer.zero_grad()
        output = ae_model(data)
        loss = criterion(output, data)
        loss.backward()
        optimizer.step()
        epoch_loss += loss.item()
    if (epoch + 1) % 10 == 0:
        print(f"Epoch [{epoch+1}/{epochs}] Loss: {epoch_loss/len(train_dataloader):.6f}")

# Calculate reconstruction error on TRAINING data for threshold
with torch.no_grad():
    X_train_tensor = torch.from_numpy(X_train_np)
    X_train_recon = ae_model(X_train_tensor).numpy()
    recon_error_train = np.mean((X_train_np - X_train_recon)**2, axis=1)

# FIX: Use distinct variable name for autoencoder threshold
ae_threshold = recon_error_train.mean() + 3 * recon_error_train.std()
ae_train_preds = (recon_error_train > ae_threshold).astype(int)

print(f"\nAutoencoder - Training anomalies detected: {ae_train_preds.sum()}/{len(ae_train_preds)}")
print(f"Autoencoder threshold: {ae_threshold:.6f}")

