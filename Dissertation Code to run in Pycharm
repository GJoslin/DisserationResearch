lof_test_preds = np.array([1 if s < 0 else 0 for s in lof_test_scores_raw])
lof_test_scores = -lof_test_scores_raw  # Higher = more anomalous

# 4. AUTOENCODER - test predictions (FIX: use ae_threshold)
X_test_np = X_test.values.astype(np.float32)
with torch.no_grad():
    X_test_tensor = torch.from_numpy(X_test_np)
    X_test_recon = ae_model(X_test_tensor).numpy()
    recon_error_test = np.mean((X_test_np - X_test_recon) ** 2, axis=1)

ae_test_preds = (recon_error_test > ae_threshold).astype(int)

print("All models evaluated on test set!")
