df['Temperature (\u00b0C)'] = df['Temperature (\u00b0C)'].ffill().bfill()
df['Blood Pressure (mmHg)'] = df['Blood Pressure (mmHg)'].ffill().bfill()

print("\nMissing values handled")
print("Remaining missing values:")
print(df.isnull().sum())

#%%
# ============================================
# REMOVING DUPLICATES
# ============================================

print(f"\nDuplicates found: {df.duplicated().sum()}")
df = df.drop_duplicates()
print(f"Duplicates removed. Rows remaining: {len(df)}")
#%%
# ============================================
# REMOVING OUTLIERS
# ============================================

print("\nChecking for outliers...")
print(f"Heart Rate < 0: {(df['Heart Rate (bpm)'] < 0).sum()}")
print(f"Heart Rate > 250: {(df['Heart Rate (bpm)'] > 250).sum()}")
print(f"Temperature < 30°C: {(df['Temperature (°C)'] < 30).sum()}")
print(f"Temperature > 45°C: {(df['Temperature (°C)'] > 45).sum()}")

# Remove biologically impossible values
df = df[(df['Heart Rate (bpm)'] >= 30) & (df['Heart Rate (bpm)'] <= 250)]
df = df[(df['Temperature (°C)'] >= 30) & (df['Temperature (°C)'] <= 45)]

print(f"Outliers removed. Rows remaining: {len(df)}")

#%%
# ============================================
# TRANSFORMING TIMESTAMP AND SORTING
# ============================================

df['Timestamp'] = pd.to_datetime(df['Timestamp'])
df = df.sort_values(['Patient ID', 'Timestamp']).reset_index(drop=True)

# Extract time-based features
df['Hour'] = df['Timestamp'].dt.hour
df['DayOfWeek'] = df['Timestamp'].dt.dayofweek

print("Timestamp converted and data sorted")

#%%
# ============================================
# FEATURE SELECTION ON COLUMNS
# ============================================

features = [
    'Patient ID',
    'Timestamp',
    'Heart Rate (bpm)',
    'Temperature (°C)',
    'Blood Pressure (mmHg)',
    'Device ID',
    'IP Address',
    'Access Type',
    'Action',
    'Target'
]

df_model = df[features].copy()
print(f"Selected {len(features)} columns for modeling")

#%%
# ============================================
# PARSING BLOOD PRESSURE
# ============================================

print("\nBlood Pressure format check:")
print(df_model['Blood Pressure (mmHg)'].head(10))

# Try to convert to numeric first
df_model['Blood Pressure (mmHg)'] = pd.to_numeric(
    df_model['Blood Pressure (mmHg)'],
    errors='coerce'
)

# If all NaN, it's in "120/80" format
if df_model['Blood Pressure (mmHg)'].isna().all():
    print("Blood Pressure is in 'systolic/diastolic' format. Splitting...")

    # Reload from original df
    df_model['Blood Pressure (mmHg)'] = df['Blood Pressure (mmHg)']

    # Split into systolic and diastolic
    bp_split = df_model['Blood Pressure (mmHg)'].str.split('/', expand=True)

    df_model['BP_Systolic'] = pd.to_numeric(bp_split[0], errors='coerce')
    df_model['BP_Diastolic'] = pd.to_numeric(bp_split[1], errors='coerce')

    # Calculate Mean Arterial Pressure (MAP)
    df_model['BP_MAP'] = (df_model['BP_Systolic'] + 2 * df_model['BP_Diastolic']) / 3

    # Drop original column
    df_model = df_model.drop(columns=['Blood Pressure (mmHg)'])

    # Fill any NaNs
    df_model['BP_Systolic'] = df_model['BP_Systolic'].ffill().bfill()
    df_model['BP_Diastolic'] = df_model['BP_Diastolic'].ffill().bfill()
    df_model['BP_MAP'] = df_model['BP_MAP'].ffill().bfill()

    print("Blood Pressure split successfully!")
    print(df_model[['BP_Systolic', 'BP_Diastolic', 'BP_MAP']].head())
else:
    print("Blood Pressure already numeric")
    df_model['Blood Pressure (mmHg)'] = df_model['Blood Pressure (mmHg)'].ffill().bfill()

#%%
# ============================================
# CREATING DEVICE-LEVEL FEATURES
# ============================================

print("\n" + "=" * 60)
print("CREATING DEVICE-LEVEL FEATURES")

# a) Device usage count
device_usage = df_model.groupby('Device ID').size()
df_model['Device_Usage_Count'] = df_model['Device ID'].map(device_usage)

# Flag devices with unusually high usage
df_model['Device_High_Usage'] = (
    df_model['Device_Usage_Count'] > df_model['Device_Usage_Count'].quantile(0.95)
).astype(int)

print("Device usage features created")

# b) Device error rate
def device_error_rate(group):
    """Calculate percentage of out-of-range readings per device"""
    errors = 0
    errors += ((group['Heart Rate (bpm)'] < 40) | (group['Heart Rate (bpm)'] > 180)).sum()
    errors += ((group['Temperature (°C)'] < 35) | (group['Temperature (°C)'] > 40)).sum()
    errors += ((group['BP_Systolic'] < 90) | (group['BP_Systolic'] > 180)).sum()
    errors += ((group['BP_Diastolic'] < 60) | (group['BP_Diastolic'] > 120)).sum()
    return errors / len(group) if len(group) > 0 else 0

device_errors = df_model.groupby('Device ID').apply(device_error_rate, include_groups=False)
df_model['Device_Error_Rate'] = df_model['Device ID'].map(device_errors)

print(f"Device error rates calculated")
print(f"  Average error rate: {df_model['Device_Error_Rate'].mean():.2%}")

# c) Network features
df_model['IP_Internal'] = df_model['IP Address'].str.startswith('192.168').astype(int)

print("Network features created")

# d) One-hot encode categorical variables
if 'Access Type' in df_model.columns:
    df_model = pd.get_dummies(df_model, columns=['Access Type'], prefix='Access')
    print("Access Type encoded")

if 'Action' in df_model.columns:
    df_model = pd.get_dummies(df_model, columns=['Action'], prefix='Action')
    print("Action encoded")

print("Device-level features complete!")

#%%
# ============================================
# CREATING PATIENT-LEVEL FEATURES
# ============================================

print("\n" + "=" * 60)
print("CREATING PATIENT-LEVEL FEATURES")

patient_stats = df_model.groupby('Patient ID').agg({
    'Heart Rate (bpm)': ['mean', 'std'],
    'Temperature (°C)': ['mean', 'std'],
    'BP_Systolic': ['mean', 'std'],
    'BP_Diastolic': ['mean', 'std'],
    'BP_MAP': ['mean', 'std']
})

patient_stats.columns = [
    'HR_mean', 'HR_std',
    'Temp_mean', 'Temp_std',
    'BP_Sys_mean', 'BP_Sys_std',
    'BP_Dia_mean', 'BP_Dia_std',
    'BP_MAP_mean', 'BP_MAP_std'
]

patient_stats = patient_stats.reset_index()
df_model = df_model.merge(patient_stats, on='Patient ID', how='left')

# Calculate deviations from patient's own baseline (z-scores)
df_model['HR_deviation_from_baseline'] = (
    df_model['Heart Rate (bpm)'] - df_model['HR_mean']
) / (df_model['HR_std'] + 1e-6)

df_model['Temp_deviation_from_baseline'] = (
    df_model['Temperature (°C)'] - df_model['Temp_mean']
) / (df_model['Temp_std'] + 1e-6)

df_model['BP_Systolic_deviation_from_baseline'] = (
    df_model['BP_Systolic'] - df_model['BP_Sys_mean']
) / (df_model['BP_Sys_std'] + 1e-6)

df_model['BP_Diastolic_deviation_from_baseline'] = (
    df_model['BP_Diastolic'] - df_model['BP_Dia_mean']
) / (df_model['BP_Dia_std'] + 1e-6)

print("Patient baseline features created!")

#%%
# ============================================
# CREATING TIME-SERIES FEATURES
# ============================================

print("\n" + "=" * 60)
print("CREATING TIME-SERIES FEATURES")
print("=" * 60)

df_model = df_model.sort_values(['Patient ID', 'Device ID', 'Timestamp']).reset_index(drop=True)

window_size = 5

for col in ['Heart Rate (bpm)', 'Temperature (°C)', 'BP_Systolic', 'BP_Diastolic', 'BP_MAP']:
    df_model[f'{col}_rolling_mean'] = df_model.groupby(['Patient ID', 'Device ID'])[col].transform(
        lambda x: x.rolling(window=window_size, min_periods=1).mean()
    )
    df_model[f'{col}_rolling_std'] = df_model.groupby(['Patient ID', 'Device ID'])[col].transform(
        lambda x: x.rolling(window=window_size, min_periods=1).std()
    )

print(f"Rolling statistics created (window size: {window_size})")

for col in ['Heart Rate (bpm)', 'Temperature (°C)', 'BP_Systolic', 'BP_Diastolic']:
    df_model[f'{col}_change'] = df_model.groupby(['Patient ID', 'Device ID'])[col].diff()

print("Rate of change features created")

df_model['Time_Since_Last_Reading'] = df_model.groupby(['Patient ID', 'Device ID'])[
    'Timestamp'].diff().dt.total_seconds()

df_model['Abnormal_Gap'] = (df_model['Time_Since_Last_Reading'] > 300).astype(int)

print("Time gap features created")
print("Time-series features complete!")

#%%
# ============================================
# DEVICE STABILITY SCORING
# ============================================

df_model['Device_Stability_Score'] = (
    1 - df_model['Device_Error_Rate']
) * (
    1 / (1 + df_model['Abnormal_Gap'])
)

print("Device stability score created!")

