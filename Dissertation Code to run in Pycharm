import lime
import lime.lime_tabular

print("=" * 60)
print("LIME EXPLANATIONS")
print("=" * 60)

# Create LIME explainer
lime_explainer = lime.lime_tabular.LimeTabularExplainer(
    training_data=X_train.values,
    feature_names=all_features,
    class_names=['Normal', 'Anomaly'],
    mode='classification',
    random_state=42
)

# ---- Helper functions to wrap each model for LIME ----

def iso_forest_predict_proba_lime(X):
    """Return [P(normal), P(anomaly)] for Isolation Forest"""
    if not isinstance(X, pd.DataFrame):
        X = pd.DataFrame(X, columns=all_features)
    scores = iso_model.decision_function(X)
    probs_anomaly = 1 / (1 + np.exp(scores * 5))  # sigmoid transformation
    probs_normal = 1 - probs_anomaly
    return np.column_stack([probs_normal, probs_anomaly])

def knn_predict_proba_lime(X):
    """Return [P(normal), P(anomaly)] for KNN"""
    if isinstance(X, pd.DataFrame):
        X_vals = X.values
    else:
        X_vals = X
    distances, _ = knn.kneighbors(X_vals)
    scores = distances.mean(axis=1)
    probs_anomaly = (scores - scores.min()) / (scores.max() - scores.min() + 1e-10)
    probs_normal = 1 - probs_anomaly
    return np.column_stack([probs_normal, probs_anomaly])

def lof_predict_proba_lime(X):
    """Return [P(normal), P(anomaly)] for LOF"""
    if not isinstance(X, pd.DataFrame):
        X = pd.DataFrame(X, columns=all_features)
    scores = lof_model.decision_function(X)
    probs_anomaly = 1 / (1 + np.exp(scores * 5))
    probs_normal = 1 - probs_anomaly
    return np.column_stack([probs_normal, probs_anomaly])

def ae_predict_proba_lime(X):
    """Return [P(normal), P(anomaly)] for Autoencoder"""
    if isinstance(X, pd.DataFrame):
        X = X.values
    input_tensor = torch.from_numpy(X.astype(np.float32))
    with torch.no_grad():
        recon = ae_model(input_tensor).numpy()
    errors = np.mean((X - recon)**2, axis=1)
    probs_anomaly = 1 / (1 + np.exp(-(errors - ae_threshold) * 10))
    probs_normal = 1 - probs_anomaly
    return np.column_stack([probs_normal, probs_anomaly])

# ---- Generate LIME explanations for sample anomalies ----

